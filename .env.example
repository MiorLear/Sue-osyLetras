# Copia este archivo a .env (ya está en .gitignore) y ajústalo si quieres —
# estos valores por defecto funcionan de una vez con `docker compose up`.

POSTGRES_DB=explorarte
POSTGRES_USER=explorarte
POSTGRES_PASSWORD=explorarte_dev_password
POSTGRES_PORT=5432

# --- Base de datos: Supabase (opcional para el stack local) ---
# VACÍO     -> el backend local usa el Postgres de Docker (servicio db).
# CON VALOR -> el backend local usa Supabase (tiene precedencia sobre los
#              SPRING_DATASOURCE_* del contenedor; misma traducción que en Render).
# Pega la cadena del "Session pooler" de tu proyecto (Supabase -> Connect ->
# Session pooler), formato:
#   postgresql://postgres.<ref>:<PASSWORD>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
# OJO: si la contraseña tiene '$', escápalo como '$$' en este archivo (docker
# compose interpola '$'). Es SECRETO — el .env real está en .gitignore.
DATABASE_URL=

API_PORT=8000
JWT_SECRET=dev-only-not-for-production-change-me
JWT_EXPIRATION_MINUTES=1440
# Contraseña fija para las cuentas de ejemplo que la API precarga (ver README).
SEED_USER_PASSWORD=explorarte123
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# --- Supabase Storage (subida de archivos) ---
# SUPABASE_URL = https://<ref>.supabase.co
# SUPABASE_KEY = service_role key (recomendada, Supabase → Project Settings → API)
#                o la anon key (requiere política RLS que permita subir).
SUPABASE_URL=
SUPABASE_KEY=

WEB_PORT=5173
VITE_API_URL=http://localhost:8000
# Módulos que la web debe seguir sirviendo desde el mock aunque VITE_API_URL
# esté configurado (lista separada por comas, ej: posts,tools). Vacío = todo real.
VITE_API_MOCK_MODULES=

# --- Mobile (Expo, corre con `npm start`, fuera de Docker) ---
# Expo Go en un teléfono físico no puede usar "localhost" — pon la IP de tu
# PC en la red local, ej: http://192.168.1.23:8000 (misma restricción que el
# QR de Expo Go). Si vas a probar en el navegador (`npm run web`) o en un
# emulador en la misma máquina, localhost:8000 sí funciona.
EXPO_PUBLIC_API_URL=http://localhost:8000
# Mismo mecanismo que VITE_API_MOCK_MODULES, para mobile.
EXPO_PUBLIC_API_MOCK_MODULES=
