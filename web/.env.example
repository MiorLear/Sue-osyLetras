# Leave VITE_API_URL unset to run against the in-memory mock client (default).
# Set it to the REST backend base URL to switch the whole app to live data —
# no screen code changes required.
# VITE_API_URL=http://localhost:8000

# Optional: comma-separated module keys (auth,emotions,posts,events,learning,
# tools,profile,misc,admin) that should keep using the mock even when
# VITE_API_URL is set above — useful while a module isn't implemented in the
# real API yet.
# VITE_API_MOCK_MODULES=posts,tools
